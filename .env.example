# Server-only keys
GEMINI_API_KEY=
UNSPLASH_ACCESS_KEY=

# Appwrite (client-visible values are typically safe; do not put server API keys behind VITE_ unless you intend to expose them)
VITE_APPWRITE_API_ENDPOINT=
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=
VITE_APPWRITE_USERS_COLLECTION_ID=
VITE_APPWRITE_TRIPS_COLLECTION_ID=

# If you are currently using an Appwrite API key in the browser, treat it as a secret and prefer server-side usage only.
VITE_APPWRITE_API_KEY=

# Other
VITE_SYNCFUSION_LICENSE_KEY=
